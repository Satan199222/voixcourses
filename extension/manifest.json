{
  "manifest_version": 3,
  "name": "VoixCourses",
  "version": "0.1.0",
  "description": "Assistant de courses accessible — transfère votre liste VoixCourses dans votre panier Carrefour.",

  "permissions": ["storage", "tabs"],

  "host_permissions": ["https://www.carrefour.fr/*"],

  "externally_connectable": {
    "matches": [
      "https://voixcourses.fr/*",
      "https://*.voixcourses.fr/*",
      "http://localhost:3000/*",
      "http://127.0.0.1:3000/*"
    ]
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.carrefour.fr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://voixcourses.fr/*",
        "https://*.voixcourses.fr/*",
        "http://localhost:3000/*",
        "http://127.0.0.1:3000/*"
      ],
      "js": ["voixcourses-marker.js"],
      "run_at": "document_start"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "VoixCourses",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
