{
  "manifest_version": 3,
  "name": "Coraly",
  "version": "0.2.0",
  "description": "Assistant de courses accessible — transfère votre liste Coraly dans votre panier Carrefour.",

  "permissions": ["storage", "tabs"],

  "host_permissions": ["https://www.carrefour.fr/*"],

  "externally_connectable": {
    "matches": [
      "https://coraly.fr/*",
      "https://*.coraly.fr/*",
      "https://coraly.vercel.app/*"
    ]
  },

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["https://www.carrefour.fr/*"],
      "js": ["voice-core.js", "content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://coraly.fr/*",
        "https://*.coraly.fr/*",
        "https://coraly.vercel.app/*"
      ],
      "js": ["coraly-marker.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://coraly.fr/*",
        "https://*.coraly.fr/*",
        "https://coraly.vercel.app/*"
      ],
      "js": ["voice-core.js", "coraly-voice.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Coraly",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },

  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
